<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Lava Rápido Brilho Total</title>

    <style>

        body {
            font-family: arial, sans-serif;
            margin:0;
            background:#f2f5fb;
        }
        
header{
    background: #0a3d91;
    color: white;
    text-align: center;
    padding: 20px;
}

nav{
    background: #0a3d91;
    color: white;
    text-align: center;
    padding: 20px;
}

nava{
    color: white;
    margin: 0 15px:
    text-decoration: none;
    font-weight:bold:
}

.banner{
background:url("https://images.unsplash.com/photo-1607860108855-64acf2078ed9") center/cover;
padding:100px 20px;
color:white;
}

.banner h1{
font-size:40px;
}

section{
padding:40px;
text-align:center;
}

.cards{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
}

.card{
background:white;
padding:20px;
width:200px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

.preco{
font-size:24px;
color:#0a3d91;
font-weight:bold;
}


.area-cliente{
background:white;
padding:40px;
margin:40px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

input{
padding:10px;
font-size:18px;
border-radius:5px;
border:1px solid #ccc;
}

button{
padding:10px 20px;
font-size:18px;
background:#1f5fbf;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

footer{
background:#0a3d91;
color:white;
text-align:center;
padding:20px;
margin-top:40px;

    </style>

</head>

<body>
    
    <header>
<h1>🚗 Lava Rápido Brilho Total</h1>
<p>Seu carro limpo e brilhando em minutos!</p>
</header>

<nav>
<a href="#">Início</a>
<a href="#">Serviços</a>
<a href="#">Preços</a>
<a href="#">Contato</a>
</nav>

<div class="banner">
<h1>Bem-vindo</h1>
<p>Oferecemos lavagem rápida, completa e com produtos de qualidade para deixar seu carro impecável.</p>
</div>

<section>

   <h2>Nossos Serviços</h2>

<div class="cards">

<div class="card">
<h3>Lavagem Simples</h3>
<p>Lavagem externa completa</p>
</div>

<div class="card">
<h3>Lavagem Completa</h3>
<p>Exterior + limpeza interna</p>
</div>

<div class="card">
<h3>Polimento</h3>
<p>Pintura renovada e brilhante</p>
</div>

<div class="card">
<h3>Higienização</h3>
<p>Limpeza profunda interna</p>
</div>

</div>

 </section>

 <section> 
    
    <h2>Preços</h2>

<div class="cards">

<div class="card">
<h3>Lavagem Simples</h3>
<p class="preco">R$ 30</p>
</div>

<div class="card">
<h3>Lavagem Completa</h3>
<p class="preco">R$ 50</p>
</div>

<div class="card">
<h3>Polimento</h3>
<p class="preco">R$ 120</p>
</div>

<div class="card">
<h3>Higienização</h3>
<p class="preco">R$ 150</p>
</div>

</div>

    </section>

    <section class = "area-cliente">
    
        <h2>Área do Cliente - Verificar Veículo</h2>
     
        <p>Digite a placa do veículo para verificar se já está pronto.</p>

<input type="text" id="placa" placeholder="Digite a placa">
<button onclick="verificar()">Verificar Status</button>

<h3 id="resultado"></h3>

</section>

<section>

<h2>Contato</h2>

<p>📍 Rua Exemplo, 123</p>
<p>📞 (11) 99999-9999</p>
<p>✉ contato@lavarapido.com</p>

    </section>

    <footer>
<p>© 2026 Lava Rápido Brilho Total</p>
</footer>

<script>

function verificar(){

let placa = document.getElementById("placa").value.toUpperCase()

if(placa == "ABC1D23"){
document.getElementById("resultado").innerHTML =
"✅ Seu veículo está pronto para retirada!"
}
else{
document.getElementById("resultado").innerHTML =
"⏳ Veículo ainda está em lavagem."
}

}

</script>

</body>
</html>
